<%- include('header.ejs') %>
<main class="dashboard-content">
  <div class="container-fluid px-3 px-lg-4 py-4">
    <div class="page-heading">
      <div class="page-heading-copy">
        <span class="page-icon"
          ><i class="bi bi-file-earmark" aria-hidden="true"></i
        ></span>
        <div>
          <p class="eyebrow mb-1">Starter</p>
          <h1 class="h3 mb-1">Services</h1>
          <p class="text-muted mb-0">
            A clean starter page for new admin screens.
          </p>
        </div>
      </div>
    </div>

    <section class="panel">
      <form action="/admin/service_save" method="post">
        <label>Title</label>
        <input type="text" class="form-control mb-4" name="stitle" id="" />
        <label>Description</label>
        <textarea class="form-control mb-4" name="sdesc" id=""></textarea>
        <button class="btn btn-primary">Save</button>
      </form>
      <table class="table table-bordered">
        <tr>
          <th>Sr.No</th>
          <th>Title</th>
          <th>Description</th>
          <th>Status</th>
        </tr>
        <% for(var i = 0; i < data.length; i++) { %>
          <tr>
            <td><%= i+1; %></td>
            <td><%= data[i].stitle; %></td>
            <td><%= data[i].sdesc; %></td>
            <td>
             <a href="/admin/service_edit/<%= data[i].sid %>"><button class="btn">Edit</button></a>
              <a href="/admin/service_delete/<%= data[i].sid %>"><button class="btn">Delete</button></a>
            </td>
          </tr>
        <% } %>
      </table>
    </section>
  </div>
</main>
<%- include('footer.ejs') %>
