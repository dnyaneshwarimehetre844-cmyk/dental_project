<%- include('header.ejs') %>
<main class="dashboard-content">
  <div class="container-fluid px-3 px-lg-4 py-4">
    <div class="page-heading">
      <div class="page-heading-copy">
        <span class="page-icon"
          ><i class="bi bi-file-earmark" aria-hidden="true"></i
        ></span>
        <div>
          <p class="eyebrow mb-1">Starter</p>
          <h1 class="h3 mb-1">Team Update</h1>
          <p class="text-muted mb-0">
            A clean starter page for new admin screens.
          </p>
        </div>
      </div>
    </div>

    <section class="panel">
      <form
        action="/admin/team_edit_save/<%= data.tid %>/<%=data.tphoto%>"
        method="post"
        enctype="multipart/form-data"
      >
        <label>Photo</label>
        <input type="file" class="form-control mb-4" name="tphoto" id="" />
        <img src="/images/<%=data.tphoto%>" alt="" height="100px" /><br />
        <label>Title</label>
        <input
          type="text"
          class="form-control mb-4"
          name="ttitle"
          id=""
          value="<%= data.ttitle %>"
        />

        <label>Description</label>
        <textarea class="form-control mb-4" name="tdesc" id="">
<%= data.tdesc %></textarea
        >
        <button class="btn btn-primary">Save</button>
      </form>
    </section>
  </div>
</main>
<%- include('footer.ejs') %>
