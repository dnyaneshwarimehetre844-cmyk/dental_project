<%- include('header.ejs') %>
<main class="dashboard-content">
  <div class="container-fluid px-3 px-lg-4 py-4">
    <div class="page-heading">
      <div class="page-heading-copy">
        <span class="page-icon"
          ><i class="bi bi-file-earmark" aria-hidden="true"></i
        ></span>
        <div>
          <p class="eyebrow mb-1">Starter</p>
          <h1 class="h3 mb-1">FAQ</h1>
          <p class="text-muted mb-0">
            A clean starter page for new admin screens.
          </p>
        </div>
      </div>
    </div>

    <section class="panel">
      <form action="/admin/faq_save" method="post">
        <label>Question</label>
        <input type="text" class="form-control mb-4" name="faq_que" />
        <label>Answer</label>
        <textarea class="form-control mb-4" name="faq_ans"></textarea>
        <button class="btn btn-primary">Save</button>
      </form>
      <table class="table table-bordered">
        <tr>
        <th>Sr.No</th>
        <th>Question</th>
        <th>Answer</th>
        <th>Status</th>
        </tr>
        <% for(var i=0;i<data.length;i++){ %>
          <tr>
         <td><%=i+1;%></td>
        <td><%=data[i].faq_que;%></td>
        <td><%=data[i].faq_ans;%></td>
            <td>
       
              <a href="/admin/faq_delete/<%=data[i].fid%>"><button class="btn">Delete</button></a>    
              <a href="/admin/faq_edit/<%=data[i].fid%>"><button class="btn">Edit</button></a>
            </td>
          </tr>
        <% } %>
      </table>
    </section>
  </div>
</main>
<%- include('footer.ejs') %>
