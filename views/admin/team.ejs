<%- include('header.ejs') %>
<main class="dashboard-content">
  <div class="container-fluid px-3 px-lg-4 py-4">
    <div class="page-heading">
      <div class="page-heading-copy">
        <span class="page-icon"
          ><i class="bi bi-file-earmark" aria-hidden="true"></i
        ></span>
        <div>
          <p class="eyebrow mb-1">Starter</p>
          <h1 class="h3 mb-1">Team</h1>
          <p class="text-muted mb-0">
            A clean starter page for new admin screens.
          </p>
        </div>
      </div>
    </div>

    <section class="panel">
      <form
        action="/admin/team_save"
        method="post"
        enctype="multipart/form-data"
      >
        <label>Photo</label>
        <input type="file" class="form-control mb-4" name="tphoto" id="" />
        <label>Title</label>
        <input type="text" class="form-control mb-4" name="ttitle" id="" />
        <label>Description</label>
        <textarea class="form-control mb-4" name="tdesc" id=""></textarea>
        <button class="btn btn-primary">Save</button>
      </form>
      <table class="table table-bordered mt-5">
        
          <tr>
            <th>Sr.No</th>
            <th>Image</th>
            <th>Title</th>
            <th>Description</th>
            <th>Status</th>
          </tr>
       
          <% for(var i=0;i<data.length;i++){ %>
          <tr>
            <td><%=i+1%></td>
            <td><img src="/images/<%=data[i].tphoto%>" width="100" alt="" /></td>
            <td><%=data[i].ttitle%></td>
            <td><%=data[i].tdesc%></td>
            <td>
                <a href="/admin/team_edit/<%=data[i].tid%>" ><button>Edit</button></a><br><br><a href="/admin/team_delete/<%=data[i].tid%>/<%=data[i].tphoto%>" ><button>Delete</button></a>
            </td>
          </tr>
          <% } %>
       

      </table>
    </section>
  </div>
</main>
<%- include('footer.ejs') %>
